<mxfile host="65bd71144e">
    <diagram id="glc-architecture" name="GLC validation and registry architecture">
        <mxGraphModel dx="1106" dy="513" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="2300" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="GLC validation, registry, and viewer architecture" style="text;html=1;strokeColor=none;fillColor=none;fontSize=26;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="1620" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="lane-user" value="Dataset owner / dataset repository" style="swimlane;html=1;startSize=28;horizontal=1;rounded=0;fillColor=#f8fbff;strokeColor=#6c8ebf;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="40" y="120" width="1620" height="520" as="geometry"/>
                </mxCell>
                <mxCell id="lane-validator" value="glc-metadata-validator" style="swimlane;html=1;startSize=28;horizontal=1;rounded=0;fillColor=#f4fff5;strokeColor=#82b366;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="40" y="670" width="1620" height="360" as="geometry"/>
                </mxCell>
                <mxCell id="lane-github" value="GitHub Actions artifacts and attestations" style="swimlane;html=1;startSize=28;horizontal=1;rounded=0;fillColor=#fbf7ff;strokeColor=#9673a6;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1060" width="1620" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="lane-registry" value="glc-registry" style="swimlane;html=1;startSize=28;horizontal=1;rounded=0;fillColor=#fff6f6;strokeColor=#b85450;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1370" width="1620" height="520" as="geometry"/>
                </mxCell>
                <mxCell id="lane-public" value="Public surfaces" style="swimlane;html=1;startSize=28;horizontal=1;rounded=0;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1920" width="1620" height="300" as="geometry"/>
                </mxCell>
                <mxCell id="step1" value="1. Build metadata package&lt;br&gt;&lt;br&gt;GLC metadata builder&lt;br&gt;https://tscnlab.github.io/glc-metadata-builder/&lt;br&gt;&lt;br&gt;Outputs datapackage.json and core metadata resources." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="650" y="160" width="400" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="step2" value="2. Dataset repo receives package&lt;br&gt;&lt;br&gt;Example: tscnlab/guidolin-glee-dataset&lt;br&gt;&lt;br&gt;Contains datapackage.json, data/*.json, data/*.csv, schemas/2.0.0, and referenced raw files." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="650" y="330" width="400" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="step3" value="3. Dataset workflow runs&lt;br&gt;&lt;br&gt;.github/workflows/validate.yml&lt;br&gt;name: Validate GLC Dataset&lt;br&gt;&lt;br&gt;Triggers: push to main, pull_request, workflow_dispatch." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="650" y="500" width="400" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="side-template" value="Template workflow&lt;br&gt;&lt;br&gt;glc-metadata-validator/templates/github-actions/validate-glc-dataset.yml&lt;br&gt;&lt;br&gt;Dataset owners copy this once into their own repo." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf3ff;strokeColor=#6c8ebf;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="110" y="500" width="360" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="side-files" value="Dataset owner view&lt;br&gt;&lt;br&gt;GitHub Actions - Validate GLC Dataset&lt;br&gt;&lt;br&gt;Shows pass/fail, logs, and downloadable validation-report artifact." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf3ff;strokeColor=#6c8ebf;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="1230" y="500" width="340" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="step4" value="4. Caller delegates to reusable trusted workflow&lt;br&gt;&lt;br&gt;jobs.validate.uses:&lt;br&gt;tscnlab/glc-metadata-validator/.github/workflows/validate.yml@v0.5.0&lt;br&gt;&lt;br&gt;The copied workflow is installation wiring, not the trust anchor." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="650" y="720" width="400" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="step5" value="5. Validator container executes checks&lt;br&gt;&lt;br&gt;Dockerfile, gleam_validator.py, schemas/2.0.0, data-package.json, data-resource.json&lt;br&gt;&lt;br&gt;Checks schema/profile validity, cross-resource references, referenced files, and checksums." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="650" y="900" width="400" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="side-validator-repo" value="Trusted reusable workflow&lt;br&gt;&lt;br&gt;glc-metadata-validator/.github/workflows/validate.yml&lt;br&gt;&lt;br&gt;Owned and versioned by the validator repo." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e9f7e9;strokeColor=#82b366;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="110" y="720" width="360" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="side-image" value="Container image identity&lt;br&gt;&lt;br&gt;ghcr.io/tscnlab/glc-validator@sha256:...&lt;br&gt;&lt;br&gt;The resolved digest is recorded in validation.json and checked by registry policy." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e9f7e9;strokeColor=#82b366;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="1230" y="900" width="340" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="step6" value="6. Validator writes outputs&lt;br&gt;&lt;br&gt;validation_out/validation.json&lt;br&gt;validation_out/validated-files-manifest.json&lt;br&gt;validation_out/validation.log&lt;br&gt;validation_out/exit_code.txt&lt;br&gt;&lt;br&gt;This workspace is temporary during the workflow run." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="650" y="1110" width="400" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="step7" value="7. GitHub stores artifact and provenance&lt;br&gt;&lt;br&gt;Artifact: validation-report&lt;br&gt;Attestation: actions/attest-build-provenance@v2&lt;br&gt;&lt;br&gt;Attestation binds outputs to workflow origin and dataset commit SHA." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="650" y="1270" width="400" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="side-artifact-files" value="validation-report contents&lt;br&gt;&lt;br&gt;validation.json: pass/fail, repo, commit, schema version, validator version, image digest&lt;br&gt;&lt;br&gt;manifest: referenced files and checksums&lt;br&gt;log: human-readable run log&lt;br&gt;exit_code: 0 or nonzero" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e7f5;strokeColor=#9673a6;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="110" y="1110" width="360" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="side-github-api" value="Registry uses GitHub API&lt;br&gt;&lt;br&gt;Resolve commit SHA&lt;br&gt;Find completed runs for SHA&lt;br&gt;Find validation-report artifact&lt;br&gt;Download artifact zip&lt;br&gt;Run gh attestation verify" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e7f5;strokeColor=#9673a6;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="1230" y="1270" width="340" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="step8" value="8. Registry source list declares tracked datasets&lt;br&gt;&lt;br&gt;glc-registry/datasets.yml&lt;br&gt;&lt;br&gt;Each entry declares repo, branch, and optional commit pin." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="650" y="1430" width="400" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="step9" value="9. Registry validates PRs and refreshes status&lt;br&gt;&lt;br&gt;PR check: scripts/validate_datasets_pr.py&lt;br&gt;Refresh: scripts/fetch_registry.py&lt;br&gt;Artifact helper: scripts/validation_artifacts.py&lt;br&gt;&lt;br&gt;New dataset entries require verified passing artifacts before merge." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="650" y="1570" width="400" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="step10" value="10. Registry enforces trust policy&lt;br&gt;&lt;br&gt;Artifact must verify against trusted signer workflow, correct dataset repo, exact commit SHA, and allowed validator image digest prefix.&lt;br&gt;&lt;br&gt;Fake or self-produced validation.json files are rejected." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="650" y="1740" width="400" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="side-policy" value="Registry membership policy&lt;br&gt;&lt;br&gt;New dataset: must pass before merge.&lt;br&gt;&lt;br&gt;Existing dataset: registry can show current pass, fail, or missing_artifact and preserve latest_pass." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="1230" y="1570" width="340" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="side-branch-protection" value="Registry governance&lt;br&gt;&lt;br&gt;datasets.yml changes go through PR review, CODEOWNERS, and required checks before merge." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="110" y="1570" width="360" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="step11" value="11. Registry publishes verified outputs&lt;br&gt;&lt;br&gt;registry_out/registry.json&lt;br&gt;registry_out/_validation_artifacts/{owner__repo}/{commit_sha}/&lt;br&gt;&lt;br&gt;Per dataset: current_status, current result, latest_pass result, attestation_verified." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#666666;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="650" y="1960" width="400" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="step12" value="12. Public viewer consumes registry&lt;br&gt;&lt;br&gt;glc-dp-viewer/pages/registry.html&lt;br&gt;&lt;br&gt;Fetches https://tscnlab.github.io/glc-registry/registry.json and displays dataset repo, current status, latest pass, commit links, and reports." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#666666;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="650" y="2120" width="400" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="side-public-endpoint" value="Published registry endpoint&lt;br&gt;&lt;br&gt;glc-registry gh-pages&lt;br&gt;https://tscnlab.github.io/glc-registry/registry.json&lt;br&gt;&lt;br&gt;Verified artifact copies are public under _validation_artifacts/." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#666666;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="110" y="1960" width="360" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="side-public-users" value="Public users and reviewers&lt;br&gt;&lt;br&gt;Can see tracked datasets, current pass/fail/missing state, last verified passing commit, dataset repos, and validation reports." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#666666;fontSize=12;align=left;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="1230" y="2120" width="340" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="e1" value="export package" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4472c4;fontSize=11;endArrow=block;endFill=1;" parent="1" source="step1" target="step2" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e2" value="push or PR" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d6b656;fontSize=11;endArrow=block;endFill=1;" parent="1" source="step2" target="step3" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e3" value="copy once" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6c8ebf;fontSize=11;dashed=1;endArrow=block;endFill=1;" parent="1" source="side-template" target="step3" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e4" value="visible result" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6c8ebf;fontSize=11;dashed=1;endArrow=block;endFill=1;" parent="1" source="step3" target="side-files" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e5" value="uses reusable workflow" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#82b366;fontSize=11;endArrow=block;endFill=1;" parent="1" source="step3" target="step4" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e6" value="owned source" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#82b366;fontSize=11;dashed=1;endArrow=block;endFill=1;" parent="1" source="side-validator-repo" target="step4" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e7" value="runs container" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#82b366;fontSize=11;endArrow=block;endFill=1;" parent="1" source="step4" target="step5" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e8" value="records digest" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#82b366;fontSize=11;dashed=1;endArrow=block;endFill=1;" parent="1" source="step5" target="side-image" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e9" value="writes files" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#9673a6;fontSize=11;endArrow=block;endFill=1;" parent="1" source="step5" target="step6" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e10" value="contains" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#9673a6;fontSize=11;dashed=1;endArrow=block;endFill=1;" parent="1" source="side-artifact-files" target="step6" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e11" value="upload and attest" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#9673a6;fontSize=11;endArrow=block;endFill=1;" parent="1" source="step6" target="step7" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e12" value="queried later" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#9673a6;fontSize=11;dashed=1;endArrow=block;endFill=1;" parent="1" source="side-github-api" target="step7" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e13" value="dataset entry" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#b85450;fontSize=11;endArrow=block;endFill=1;" parent="1" source="step7" target="step8" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e14" value="PR check or schedule" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#b85450;fontSize=11;endArrow=block;endFill=1;" parent="1" source="step8" target="step9" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e15" value="protected updates" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#b85450;fontSize=11;dashed=1;endArrow=block;endFill=1;" parent="1" source="side-branch-protection" target="step9" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e16" value="policy" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#b85450;fontSize=11;dashed=1;endArrow=block;endFill=1;" parent="1" source="side-policy" target="step9" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e17" value="verify artifact" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#b85450;fontSize=11;endArrow=block;endFill=1;" parent="1" source="step9" target="step10" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e18" value="publish verified state" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;fontSize=11;endArrow=block;endFill=1;" parent="1" source="step10" target="step11" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e19" value="gh-pages endpoint" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;fontSize=11;dashed=1;endArrow=block;endFill=1;" parent="1" source="side-public-endpoint" target="step11" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e20" value="fetch registry.json" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;fontSize=11;endArrow=block;endFill=1;" parent="1" source="step11" target="step12" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e21" value="display to users" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;fontSize=11;dashed=1;endArrow=block;endFill=1;" parent="1" source="step12" target="side-public-users" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
